.DS_Store

# Generated host security data (contains plaintext passwords)
token-map.json

# Track all hosts/ subdirectories (venue pages + ops dashboard)
# Venue pages have noindex/nofollow and no host PII — safe to track

# Wrangler cache (contains account credentials)
.wrangler/

# Python bytecode
__pycache__/

# App installers
*.dmg

# Rendered output (HTML source is canonical)
*.pdf

# Backup files
*.bak

# Local editor/tool config
.obsidian/
.claude/

# Compressed archives
context.zip

# Regenerable caches
.airtable-cache.json

# Session archaeology (local reference only)
context/
